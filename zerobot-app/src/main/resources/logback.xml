<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%cyan([%thread]) %highlight(%-5level) %green(%logger{36}) - %msg%n</pattern>
            <charset>${ZERO_BOT_CONSOLE_CHARSET:-UTF-8}</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="console"/>
    </root>
</configuration>
